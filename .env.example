# API
API_PORT=8080
API_KEY=supersecret_change_me
CORS_ORIGINS=http://localhost:8080
RATE_LIMIT_PER_MIN=6000

# Postgres
POSTGRES_USER=secai
POSTGRES_PASSWORD=secai_pw
POSTGRES_DB=secai
POSTGRES_PORT=5432

# MinIO
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=admin12345
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_BUCKET=secai-lake
MINIO_HOST=minio:9000
MINIO_ACCESS_KEY=admin
MINIO_SECRET_KEY=admin12345
MINIO_SECURE=false

# Qdrant
QDRANT_PORT=6333

# Neo4j
NEO4J_PORT=7474
NEO4J_BOLT_PORT=7687
NEO4J_AUTH=neo4j/testpassword

# Optional external API keys
NVD_API_KEY=
LLM_API_KEY=
CLOUDFLARE_TUNNEL_TOKEN=

# Feature flags
AUTO_INDEX=true
GEOIP_ENABLED=true
GRAPH_ENABLED=true
LAB_ENABLED=true
AGENTS_ENABLED=true
DL_LITE_ENABLED=false
LLM_ENABLED=false

# GeoIP paths (mounted via docker-compose)
MAXMIND_CITY_DB=/data/maxmind/GeoLite2-City.mmdb
MAXMIND_ASN_DB=/data/maxmind/GeoLite2-ASN.mmdb

# Policy / Firewall / Provenance
POLICY_PATH=/app/services/api/policies/default.yml
FIREWALL_MAX_TEXT=8000
PROVENANCE_STRICT=false
PROVENANCE_SIGNING_KEY=secpurityai-dev-key

# High-assurance sandbox mode
TEE_ENABLED=false

# KEV feed defaults
KEV_SYNC_ENABLED=true
KEV_SYNC_INTERVAL_MIN=1440
KEV_SYNC_ON_START=true
